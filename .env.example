# CONFIGURACION DE ENTORNO - POLITICAL DATA PERU

# base de datos postgres
DB_USER=postgres
DB_PASSWORD=secret
DB_HOST=localhost
DB_PORT=5432
DB_NAME=political_db

# configuracion de ingesta
# ruta base donde se guardaran los datos raw (dentro del contenedor o local)
DATA_RAW_PATH=./data/raw
DATA_INTERIM_PATH=./data/interim
DATA_PROCESSED_PATH=./data/processed

# limites y reintentos para scrappers
MAX_RETRIES=3
FETCH_TIMEOUT=30

# api keys (ejemplo si se usa alguna externa en el futuro)
JNE_API_TOKEN=your_token_here
CONGRESO_API_TOKEN=your_token_here